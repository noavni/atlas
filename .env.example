# ============================================================================
# Atlas — environment template
# Copy to .env.local for Next.js dev; duplicate values into Vercel project env.
# ============================================================================

# --- Supabase (public / browser) -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Supabase (server-only) ------------------------------------------------
# service-role key is used by the FastAPI worker for privileged operations
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Worker auth -----------------------------------------------------------
# Shared secret that pg_cron presents in the x-worker-secret header when
# triggering /api/internal/worker/drain
WORKER_SHARED_SECRET=change-me-generate-a-long-random-string

# --- AI providers ----------------------------------------------------------
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
# OPENAI_API_KEY=      # Phase 5 — not needed yet
# ELEVENLABS_API_KEY=  # later, when STT is wired
