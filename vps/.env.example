# Copy to .env and fill in. setup.ps1 will prompt if missing.
# ============================================================

# Shared secret — must match VPS_WORKER_SECRET in Vercel env.
WORKER_SECRET=change-me-please-make-it-long-and-random

# Supabase project connection (service role — write access).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Which whisper.cpp model file to load from ./models/
# Default is Hebrew-optimized large-v3-turbo at q5_0 quant (~574MB RAM, ~2x realtime on 4 vCPU)
WHISPER_MODEL=ggml-large-v3-turbo-q5_0.bin

# How many CPU threads whisper.cpp may use. Tune to your vCPU count.
WHISPER_THREADS=4

# Max seconds for a single transcription before we give up.
TRANSCRIBE_TIMEOUT_S=600

# Listen address for uvicorn. Default to loopback; Caddy / Cloudflare
# Tunnel proxies in from the public side.
HOST=127.0.0.1
PORT=8080

LOG_LEVEL=INFO
